---
import Layout from "@/layouts/Layout.astro";
import ResetPasswordForm from "@/components/auth/ResetPasswordForm";

const error = Astro.url.searchParams.get("error");
const sent = Astro.url.searchParams.get("sent") === "1";
---

<Layout title="Reset password">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1
        class="mb-3 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent"
      >
        Reset password
      </h1>
      <p class="mb-6 text-center text-sm text-blue-100/70">
        Enter the email tied to your account and we&apos;ll send you a reset link that returns to this app.
      </p>

      {
        sent && (
          <p class="mb-4 rounded-lg border border-emerald-500/30 bg-emerald-900/30 px-3 py-2 text-sm text-emerald-200">
            If an account exists for that email, a reset link is on its way. Open the newest email to continue on the
            password update page.
          </p>
        )
      }

      <ResetPasswordForm serverError={error} client:load />

      <p class="mt-4 text-center text-sm text-blue-100/60">
        Remembered your password? <a href="/auth/signin" class="text-purple-300 hover:underline">Sign in</a>
      </p>
    </div>
  </div>
</Layout>
