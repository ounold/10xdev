---
import Layout from "@/layouts/Layout.astro";
import UpdatePasswordForm from "@/components/auth/UpdatePasswordForm";

const error = Astro.url.searchParams.get("error");
const recoveryReady = Astro.url.searchParams.get("recovery") === "ready";
---

<Layout title="Update password">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1
        class="mb-3 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent"
      >
        Update password
      </h1>
      <p class="mb-6 text-center text-sm text-blue-100/70">
        We&apos;re verifying your recovery link before we let you set a new password.
      </p>

      {
        error && (
          <div class="space-y-4">
            <p class="rounded-lg border border-amber-400/30 bg-amber-950/40 px-3 py-2 text-sm text-amber-100">
              {error}
            </p>
            <p class="text-center text-sm text-blue-100/60">
              <a href="/auth/reset-password" class="text-purple-300 hover:underline">
                Request a new reset email
              </a>
            </p>
          </div>
        )
      }

      {
        recoveryReady && (
          <div class="space-y-4">
            <p class="rounded-lg border border-emerald-500/30 bg-emerald-900/30 px-3 py-2 text-sm text-emerald-200">
              Recovery verified. Choose a new password to continue into the app.
            </p>
            <UpdatePasswordForm serverError={error} client:load />
          </div>
        )
      }

      {
        !error && !recoveryReady && (
          <div class="space-y-4">
            <p class="rounded-lg border border-amber-400/30 bg-amber-950/40 px-3 py-2 text-sm text-amber-100">
              Open this page only from a verified recovery link. To start over, request a new reset email.
            </p>
            <p class="text-center text-sm text-blue-100/60">
              <a href="/auth/reset-password" class="text-purple-300 hover:underline">
                Request a new reset email
              </a>
            </p>
          </div>
        )
      }
    </div>
  </div>
</Layout>
