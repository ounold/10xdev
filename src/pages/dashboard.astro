---
import Layout from "@/layouts/Layout.astro";
import { listProfessorStudents } from "@/lib/supervision";
import { createClient } from "@/lib/supabase";

const { user, role } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const students = supabase ? await listProfessorStudents(supabase) : [];
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen p-4 text-white">
    <div class="mx-auto flex max-w-5xl flex-col gap-6 py-10">
      <section class="rounded-[2rem] border border-white/10 bg-white/8 p-8 backdrop-blur-xl">
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <div class="max-w-2xl">
            <p class="mb-3 text-xs tracking-[0.3em] text-cyan-200/70 uppercase">Professor workspace</p>
            <h1
              class="bg-gradient-to-r from-cyan-100 via-sky-100 to-emerald-100 bg-clip-text text-4xl font-semibold text-transparent"
            >
              Student threads
            </h1>
            <p class="mt-3 text-sm leading-6 text-slate-200/80">
              Open one supervision thread at a time. This entry surface stays intentionally thin so we can focus on note
              continuity before the broader roster experience lands.
            </p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-slate-950/20 px-4 py-3 text-sm text-slate-100/80">
            <p>
              Signed in as <span class="font-semibold text-white">{user?.email}</span>
            </p>
            <p class="mt-1 text-slate-300/70">
              Current app role: <span class="font-medium text-white">{role ?? "unknown"}</span>
            </p>
          </div>
        </div>
      </section>

      <section class="grid gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(20rem,1fr)]">
        <div class="rounded-[2rem] border border-white/10 bg-slate-950/25 p-6 backdrop-blur-xl">
          <div class="mb-5 flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-white">Available student threads</p>
              <p class="mt-1 text-sm text-slate-300/70">
                Pick a student to enter their note history. Student creation stays out of this slice.
              </p>
            </div>
            <span class="rounded-full border border-cyan-300/20 bg-cyan-300/10 px-3 py-1 text-xs text-cyan-100/80">
              {students.length} thread{students.length === 1 ? "" : "s"}
            </span>
          </div>

          {
            students.length === 0 ? (
              <div class="rounded-2xl border border-dashed border-white/15 bg-white/5 p-6 text-sm text-slate-300/75">
                No supervised students are available yet in this environment. Seed or create them outside this slice,
                then return here to open a thread.
              </div>
            ) : (
              <ul class="grid gap-3">
                {students.map((student) => (
                  <li>
                    <a
                      href={`/dashboard/students/${student.id}`}
                      class="group flex items-center justify-between gap-4 rounded-2xl border border-white/8 bg-white/[0.04] px-4 py-4 transition hover:border-cyan-300/30 hover:bg-cyan-300/[0.08]"
                    >
                      <div>
                        <p class="font-medium text-white transition group-hover:text-cyan-100">{student.full_name}</p>
                        <p class="mt-1 text-sm text-slate-300/70">{student.email ?? "No linked email yet"}</p>
                      </div>
                      <div class="text-right text-xs text-slate-300/75">
                        <p>
                          {student.note_count} note{student.note_count === 1 ? "" : "s"}
                        </p>
                        <p class="mt-1">
                          {student.last_meeting_date ? `Last meeting ${student.last_meeting_date}` : "No meetings yet"}
                        </p>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>

        <aside
          class="rounded-[2rem] border border-white/10 bg-linear-to-b from-white/10 to-white/[0.03] p-6 backdrop-blur-xl"
        >
          <p class="text-xs tracking-[0.25em] text-emerald-200/70 uppercase">Phase 1</p>
          <h2 class="mt-3 text-xl font-semibold text-white">Thin by design</h2>
          <p class="mt-3 text-sm leading-6 text-slate-200/75">
            This screen is just enough to open one student thread. It is not the future roster-management surface, and
            it avoids absorbing student creation, filtering, or admin controls too early.
          </p>
          <form method="POST" action="/api/auth/signout" class="mt-6">
            <button
              type="submit"
              class="rounded-xl border border-white/15 bg-white/8 px-4 py-2 text-sm text-white transition hover:bg-white/15"
            >
              Sign out
            </button>
          </form>
        </aside>
      </section>
    </div>
  </div>
</Layout>
