---
import Layout from "@/layouts/Layout.astro";
import StudentNoteForm from "@/components/supervision/StudentNoteForm";
import {
  getLinkedStudentHistoryForUser,
  listArchivedProfessorStudents,
  listProfessorStudents,
} from "@/lib/supervision";
import { createClient } from "@/lib/supabase";

const { user, role, isLinkedStudent } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const isStudentDashboard = role === "student" && isLinkedStudent;
const students = supabase && role === "professor" ? await listProfessorStudents(supabase) : [];
const archivedStudents = supabase && role === "professor" ? await listArchivedProfessorStudents(supabase) : [];
const linkedStudentHistory =
  supabase && user && isStudentDashboard ? await getLinkedStudentHistoryForUser(supabase, user.id) : null;
const searchParams = Astro.url.searchParams;
const creationError = searchParams.get("creationError");
const creationReady = searchParams.get("creationReady");
const createdStudent = searchParams.get("createdStudent");
const draftFullName = searchParams.get("draftFullName") ?? "";
const draftEmail = searchParams.get("draftEmail") ?? "";
const updated = searchParams.get("updated") === "1";
const taskUpdated = searchParams.get("taskUpdated");
const passwordUpdated = searchParams.get("passwordUpdated") === "1";
const archived = searchParams.get("archived") === "1";
const archivedStudent = searchParams.get("archivedStudent");
const rosterView = searchParams.get("roster") === "archived" ? "archived" : "active";
const error = searchParams.get("error");
const editNoteId = searchParams.get("edit");
const noteBeingEdited = linkedStudentHistory?.notes.find((note) => note.id === editNoteId) ?? null;

function formatMeetingDate(value: string) {
  return new Date(`${value}T00:00:00`).toLocaleDateString("en-CA", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function getLastEditorLabel(noteUpdatedBy: string) {
  if (!linkedStudentHistory) {
    return "Current collaborator";
  }

  if (noteUpdatedBy === linkedStudentHistory.student_profile_id) {
    return linkedStudentHistory.full_name;
  }

  if (noteUpdatedBy === linkedStudentHistory.professor_profile_id) {
    return "Professor";
  }

  return "Current collaborator";
}

function getCompletionActorLabel(completedBy: string) {
  if (!linkedStudentHistory) {
    return "Current collaborator";
  }

  if (completedBy === linkedStudentHistory.student_profile_id) {
    return linkedStudentHistory.full_name;
  }

  if (completedBy === linkedStudentHistory.professor_profile_id) {
    return "Professor";
  }

  return "Current collaborator";
}

function formatCompletionTimestamp(value: string) {
  return new Date(value).toLocaleString("en-GB", {
    year: "numeric",
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}

function getProfessorLinkStatusBadge(student: (typeof students)[number]) {
  if (student.linking_status === "linked") {
    return {
      label: "Linked",
      tone: "border-emerald-300/20 bg-emerald-300/10 text-emerald-100",
      detail: "Student already claimed access",
    };
  }

  if (student.linking_status === "claim-ready") {
    return {
      label: "Email ready",
      tone: "border-amber-300/20 bg-amber-300/10 text-amber-100",
      detail: "Waiting for student claim",
    };
  }

  return {
    label: "Missing email",
    tone: "border-slate-300/20 bg-slate-300/10 text-slate-100",
    detail: "Professor still needs an email anchor",
  };
}

function getProfessorArchiveStatusBadge() {
  return {
    label: "Archived",
    tone: "border-rose-300/20 bg-rose-300/10 text-rose-100",
    detail: "Professor-only history",
  };
}
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen p-4 text-white">
    <div class="mx-auto flex max-w-5xl flex-col gap-6 py-10">
      {
        isStudentDashboard ? (
          <>
            <section class="rounded-[2rem] border border-white/10 bg-white/8 p-8 backdrop-blur-xl">
              <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
                <div class="max-w-2xl">
                  <p class="mb-3 text-xs tracking-[0.3em] text-emerald-200/70 uppercase">Student workspace</p>
                  <h1 class="bg-gradient-to-r from-emerald-100 via-sky-100 to-cyan-100 bg-clip-text text-4xl font-semibold text-transparent">
                    Your supervision history
                  </h1>
                  <p class="mt-3 text-sm leading-6 text-slate-200/80">
                    This student dashboard stays limited to the linked student's own supervision history. It avoids
                    professor-only roster surfaces while allowing note continuity updates inside the shared thread.
                  </p>
                </div>
                <div class="rounded-2xl border border-white/10 bg-slate-950/20 px-4 py-3 text-sm text-slate-100/80">
                  <p>
                    Signed in as <span class="font-semibold text-white">{user?.email}</span>
                  </p>
                  <p class="mt-1 text-slate-300/70">
                    Current app role: <span class="font-medium text-white">{role}</span>
                  </p>
                </div>
              </div>
            </section>

            <section class="grid gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(20rem,1fr)]">
              <div class="rounded-[2rem] border border-white/10 bg-slate-950/25 p-6 backdrop-blur-xl">
                <div class="rounded-2xl border border-emerald-300/15 bg-emerald-300/[0.08] p-4 text-sm text-emerald-50/90">
                  <p class="font-medium text-white">
                    {linkedStudentHistory ? linkedStudentHistory.full_name : "Linked student access confirmed"}
                  </p>
                  <p class="mt-2 leading-6 text-emerald-50/80">
                    {linkedStudentHistory
                      ? "This view shows only your own supervision history and keeps edits inside the shared student thread."
                      : "The app recognizes this account as a linked student, but the linked supervision record could not be loaded."}
                  </p>
                </div>

                {updated ? (
                  <div class="mt-5 rounded-2xl border border-emerald-300/20 bg-emerald-300/10 px-4 py-3 text-sm text-emerald-50">
                    Your note changes were saved to the shared thread.
                  </div>
                ) : null}

                {taskUpdated === "complete" ? (
                  <div class="mt-5 rounded-2xl border border-emerald-300/20 bg-emerald-300/10 px-4 py-3 text-sm text-emerald-50">
                    The task was marked as completed in the shared thread.
                  </div>
                ) : null}

                {taskUpdated === "incomplete" ? (
                  <div class="mt-5 rounded-2xl border border-amber-300/20 bg-amber-300/10 px-4 py-3 text-sm text-amber-50">
                    The task was reopened in the shared thread.
                  </div>
                ) : null}

                {passwordUpdated ? (
                  <div class="mt-5 rounded-2xl border border-emerald-300/20 bg-emerald-300/10 px-4 py-3 text-sm text-emerald-50">
                    Your password was updated and this session is ready to continue.
                  </div>
                ) : null}

                <div class="mt-5 rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-sm font-medium text-white">Your history</p>
                      <p class="mt-2 text-sm leading-6 text-slate-300/75">
                        {linkedStudentHistory
                          ? "Meeting notes are shown below in reverse chronological order. Informational items stay separate from follow-up tasks."
                          : "No linked supervision record is available to render yet."}
                      </p>
                    </div>
                    <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-200/80">
                      {linkedStudentHistory
                        ? `${linkedStudentHistory.notes.length} note${linkedStudentHistory.notes.length === 1 ? "" : "s"}`
                        : "0 notes"}
                    </span>
                  </div>

                  {linkedStudentHistory ? (
                    linkedStudentHistory.notes.length === 0 ? (
                      <div class="mt-5 rounded-2xl border border-dashed border-white/15 bg-slate-950/30 p-5 text-sm text-slate-300/75">
                        No meeting notes are visible yet for this student record.
                      </div>
                    ) : (
                      <ol class="mt-5 space-y-4">
                        {linkedStudentHistory.notes.map((note) => (
                          <li class="rounded-2xl border border-white/10 bg-slate-950/35 p-5">
                            <div class="flex flex-wrap items-start justify-between gap-3">
                              <div>
                                <p class="text-sm font-medium text-white">{formatMeetingDate(note.meeting_date)}</p>
                                <p class="mt-1 text-xs text-slate-400/80">
                                  {note.items.length} item{note.items.length === 1 ? "" : "s"}
                                </p>
                                <p class="mt-1 text-xs text-slate-400/80">
                                  Last edited by {getLastEditorLabel(note.updated_by)} on{" "}
                                  {new Date(note.updated_at).toLocaleString("en-GB")}
                                </p>
                              </div>
                              <div class="flex flex-wrap items-center gap-2">
                                <span class="rounded-full border border-cyan-300/20 bg-cyan-300/10 px-3 py-1 text-xs text-cyan-50/80">
                                  Shared thread
                                </span>
                                <a
                                  href={`/dashboard?edit=${note.id}`}
                                  class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-100 transition hover:bg-white/10"
                                >
                                  Edit note
                                </a>
                              </div>
                            </div>

                            <ul class="mt-4 space-y-3">
                              {note.items.map((item) => (
                                <li
                                  class:list={[
                                    "rounded-xl border p-3",
                                    item.item_type === "task" && item.completed_at
                                      ? "border-emerald-300/20 bg-emerald-300/[0.08]"
                                      : "border-white/8 bg-white/[0.04]",
                                  ]}
                                >
                                  <div class="flex flex-wrap items-center justify-between gap-3">
                                    <div class="flex flex-wrap items-center gap-2">
                                      <span
                                        class:list={[
                                          "rounded-full px-2.5 py-1 text-[11px] font-medium tracking-[0.2em] uppercase",
                                          item.item_type === "task"
                                            ? "border border-amber-300/25 bg-amber-300/10 text-amber-100"
                                            : "border border-sky-300/25 bg-sky-300/10 text-sky-100",
                                        ]}
                                      >
                                        {item.item_type}
                                      </span>
                                      <span class="text-xs text-slate-400/75">Item {item.position}</span>
                                    </div>

                                    {item.item_type === "task" ? (
                                      <form
                                        method="POST"
                                        action={`/api/dashboard/notes/${note.id}/items/${item.id}/completion`}
                                        class="flex items-center gap-2"
                                      >
                                        <input
                                          type="hidden"
                                          name="state"
                                          value={item.completed_at ? "incomplete" : "complete"}
                                        />
                                        <input
                                          type="hidden"
                                          name="returnToEdit"
                                          value={editNoteId === note.id ? note.id : ""}
                                        />
                                        <button
                                          type="submit"
                                          class:list={[
                                            "rounded-full border px-3 py-1.5 text-xs font-medium transition",
                                            item.completed_at
                                              ? "border-amber-300/25 bg-amber-300/10 text-amber-50 hover:bg-amber-300/20"
                                              : "border-emerald-300/25 bg-emerald-300/10 text-emerald-50 hover:bg-emerald-300/20",
                                          ]}
                                        >
                                          {item.completed_at ? "Reopen task" : "Mark done"}
                                        </button>
                                      </form>
                                    ) : null}
                                  </div>

                                  <p
                                    class:list={[
                                      "mt-3 text-sm leading-6 text-slate-100/90",
                                      item.item_type === "task" &&
                                        item.completed_at &&
                                        "text-slate-300/80 line-through",
                                    ]}
                                  >
                                    {item.content}
                                  </p>

                                  {item.item_type === "task" && item.completed_at && item.completed_by ? (
                                    <p class="mt-2 text-xs text-emerald-100/80">
                                      Completed by {getCompletionActorLabel(item.completed_by)} on{" "}
                                      {formatCompletionTimestamp(item.completed_at)}
                                    </p>
                                  ) : null}
                                </li>
                              ))}
                            </ul>
                          </li>
                        ))}
                      </ol>
                    )
                  ) : null}
                </div>

                {linkedStudentHistory && noteBeingEdited ? (
                  <section class="mt-5 rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                    <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
                      <div>
                        <p class="text-xs tracking-[0.3em] text-emerald-200/70 uppercase">Edit note</p>
                        <h2 class="mt-2 text-xl font-semibold text-white">
                          Update {noteBeingEdited.meeting_date} inside your shared thread
                        </h2>
                        <p class="mt-2 text-sm leading-6 text-slate-300/75">
                          Edit saved items in place and append new ones at the end. Task completion now stays in the
                          thread itself, while professor-only routes and item deletion remain out of scope.
                        </p>
                      </div>
                    </div>

                    {error ? (
                      <div class="mt-4 rounded-2xl border border-rose-300/20 bg-rose-300/10 px-4 py-3 text-sm text-rose-50">
                        {error}
                      </div>
                    ) : null}

                    <div class="mt-4">
                      <StudentNoteForm
                        client:load
                        action={`/api/dashboard/notes/${noteBeingEdited.id}`}
                        defaultMeetingDate={noteBeingEdited.meeting_date}
                        defaultItems={noteBeingEdited.items.map((item) => ({
                          id: item.id,
                          itemType: item.item_type,
                          content: item.content,
                        }))}
                        meetingDateReadOnly={true}
                        mode="edit"
                        noteId={noteBeingEdited.id}
                      />
                    </div>
                  </section>
                ) : null}
              </div>

              <aside class="rounded-[2rem] border border-white/10 bg-linear-to-b from-white/10 to-white/[0.03] p-6 backdrop-blur-xl">
                <p class="text-xs tracking-[0.25em] text-emerald-200/70 uppercase">Phase 3</p>
                <h2 class="mt-3 text-xl font-semibold text-white">Shared student continuity</h2>
                <p class="mt-3 text-sm leading-6 text-slate-200/75">
                  This student branch now keeps the same student-only visibility boundary while opening a narrow edit
                  path for shared note continuity.
                </p>
                <div class="mt-6 rounded-2xl border border-white/10 bg-slate-950/25 p-4 text-sm text-slate-200/80">
                  <p class="font-medium text-white">Student scope</p>
                  <p class="mt-2 leading-6">
                    Only the linked student's own history is visible here. Notes can be edited in place and shared tasks
                    can be toggled inline, without exposing professor-only roster surfaces.
                  </p>
                </div>
                <form method="POST" action="/api/auth/signout" class="mt-6">
                  <button
                    type="submit"
                    class="rounded-xl border border-white/15 bg-white/8 px-4 py-2 text-sm text-white transition hover:bg-white/15"
                  >
                    Sign out
                  </button>
                </form>
              </aside>
            </section>
          </>
        ) : (
          <>
            <section class="rounded-[2rem] border border-white/10 bg-white/8 p-8 backdrop-blur-xl">
              <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
                <div class="max-w-2xl">
                  <p class="mb-3 text-xs tracking-[0.3em] text-cyan-200/70 uppercase">Professor workspace</p>
                  <h1 class="bg-gradient-to-r from-cyan-100 via-sky-100 to-emerald-100 bg-clip-text text-4xl font-semibold text-transparent">
                    Student threads
                  </h1>
                  <p class="mt-3 text-sm leading-6 text-slate-200/80">
                    Open one supervision thread at a time. This entry surface stays intentionally thin so we can focus
                    on note continuity before the broader roster experience lands.
                  </p>
                </div>
                <div class="rounded-2xl border border-white/10 bg-slate-950/20 px-4 py-3 text-sm text-slate-100/80">
                  <p>
                    Signed in as <span class="font-semibold text-white">{user?.email}</span>
                  </p>
                  <p class="mt-1 text-slate-300/70">
                    Current app role: <span class="font-medium text-white">{role}</span>
                  </p>
                </div>
              </div>
            </section>

            <section class="grid gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(20rem,1fr)]">
              <div class="rounded-[2rem] border border-white/10 bg-slate-950/25 p-6 backdrop-blur-xl">
                <div class="mb-5 grid gap-4 xl:grid-cols-[minmax(0,1.1fr)_minmax(20rem,0.9fr)]">
                  <div class="rounded-2xl border border-emerald-300/15 bg-emerald-300/[0.08] p-4 text-sm text-emerald-50/90">
                    <p class="font-medium text-white">Student roster home</p>
                    <p class="mt-2 leading-6 text-emerald-50/80">
                      Add a student here, then keep working from the same roster into that student&apos;s thread. This
                      stays intentionally lean: create and browse now, broader management later.
                    </p>
                  </div>

                  <form
                    method="POST"
                    action="/api/dashboard/students"
                    class="rounded-2xl border border-white/10 bg-white/[0.04] p-4"
                  >
                    <div class="flex items-start justify-between gap-4">
                      <div>
                        <p class="text-sm font-medium text-white">Add a student</p>
                        <p class="mt-1 text-xs leading-5 text-slate-300/75">
                          Create a professor-owned roster record with the minimum MVP details.
                        </p>
                      </div>
                      <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] tracking-[0.2em] text-slate-200/75 uppercase">
                        MVP
                      </span>
                    </div>

                    <div class="mt-4 grid gap-3">
                      <label class="space-y-2">
                        <span class="text-xs font-medium tracking-[0.2em] text-slate-300/80 uppercase">Full name</span>
                        <input
                          type="text"
                          name="fullName"
                          value={draftFullName}
                          placeholder="First Student"
                          class="w-full rounded-xl border border-white/10 bg-slate-950/50 px-3 py-2 text-sm text-white transition outline-none focus:border-cyan-300/40"
                          required
                        />
                      </label>

                      <label class="space-y-2">
                        <span class="text-xs font-medium tracking-[0.2em] text-slate-300/80 uppercase">
                          Email (optional)
                        </span>
                        <input
                          type="email"
                          name="email"
                          value={draftEmail}
                          placeholder="student@example.com"
                          class="w-full rounded-xl border border-white/10 bg-slate-950/50 px-3 py-2 text-sm text-white transition outline-none focus:border-cyan-300/40"
                        />
                      </label>
                    </div>

                    <div class="mt-4 flex items-center justify-between gap-3 border-t border-white/10 pt-4">
                      <p class="text-xs leading-5 text-slate-300/70">
                        Name is required. Email can stay blank until account linking exists.
                      </p>
                      <button
                        type="submit"
                        class="rounded-xl border border-cyan-300/20 bg-cyan-300/15 px-4 py-2 text-sm font-medium text-cyan-50 transition hover:bg-cyan-300/25"
                      >
                        Create student
                      </button>
                    </div>
                  </form>
                </div>

                {creationReady ? (
                  <div class="mb-5 rounded-2xl border border-cyan-300/20 bg-cyan-300/[0.08] p-4 text-sm text-cyan-50/90">
                    {createdStudent
                      ? `${createdStudent} is now part of the roster.`
                      : "The student was added to the roster."}
                  </div>
                ) : null}

                {creationError ? (
                  <div class="mb-5 rounded-2xl border border-rose-300/20 bg-rose-300/[0.08] p-4 text-sm text-rose-50/90">
                    {creationError}
                  </div>
                ) : null}

                {archived ? (
                  <div class="mb-5 rounded-2xl border border-emerald-300/20 bg-emerald-300/[0.08] p-4 text-sm text-emerald-50/90">
                    {archivedStudent
                      ? `${archivedStudent} was archived and removed from the active roster.`
                      : "The student was archived and removed from the active roster."}
                  </div>
                ) : null}

                {passwordUpdated ? (
                  <div class="mb-5 rounded-2xl border border-emerald-300/20 bg-emerald-300/[0.08] p-4 text-sm text-emerald-50/90">
                    Your password was updated and this session is ready to continue.
                  </div>
                ) : null}

                <div class="mb-5 flex items-center justify-between gap-4">
                  <div>
                    <p class="text-sm font-medium text-white">
                      {rosterView === "archived" ? "Archived student threads" : "Available student threads"}
                    </p>
                    <p class="mt-1 text-sm text-slate-300/70">
                      {rosterView === "archived"
                        ? "Switch into archived supervision history without mixing those records back into the active roster."
                        : "Pick a student to enter their note history. New students appear here immediately after creation."}
                    </p>
                  </div>
                  <div class="flex items-center gap-3">
                    <div class="inline-flex rounded-full border border-white/10 bg-white/5 p-1 text-xs">
                      <a
                        href="/dashboard"
                        class:list={[
                          "rounded-full px-3 py-1 transition",
                          rosterView === "active"
                            ? "bg-cyan-300/15 text-cyan-50"
                            : "text-slate-300/80 hover:text-white",
                        ]}
                      >
                        Active
                      </a>
                      <a
                        href="/dashboard?roster=archived"
                        class:list={[
                          "rounded-full px-3 py-1 transition",
                          rosterView === "archived"
                            ? "bg-rose-300/15 text-rose-50"
                            : "text-slate-300/80 hover:text-white",
                        ]}
                      >
                        Archived
                      </a>
                    </div>
                    <span
                      class:list={[
                        "rounded-full px-3 py-1 text-xs",
                        rosterView === "archived"
                          ? "border border-rose-300/20 bg-rose-300/10 text-rose-100/80"
                          : "border border-cyan-300/20 bg-cyan-300/10 text-cyan-100/80",
                      ]}
                    >
                      {rosterView === "archived" ? archivedStudents.length : students.length} thread
                      {(rosterView === "archived" ? archivedStudents.length : students.length) === 1 ? "" : "s"}
                    </span>
                  </div>
                </div>

                {(rosterView === "archived" ? archivedStudents : students).length === 0 ? (
                  <div class="rounded-2xl border border-dashed border-white/15 bg-white/5 p-6 text-sm text-slate-300/75">
                    {rosterView === "archived"
                      ? "No archived student threads are available yet. Archive an active linked student first, then return here to review the historical thread."
                      : "No supervised students are available yet. Add the first student from the form above, then return here to open their thread."}
                  </div>
                ) : (
                  <ul class="grid gap-3">
                    {(rosterView === "archived" ? archivedStudents : students).map((student) => (
                      <li>
                        {(() => {
                          const linkStatus =
                            rosterView === "archived"
                              ? getProfessorArchiveStatusBadge()
                              : getProfessorLinkStatusBadge(student);

                          return (
                            <a
                              href={
                                rosterView === "archived"
                                  ? `/dashboard/students/${student.id}?roster=archived`
                                  : `/dashboard/students/${student.id}`
                              }
                              class="group flex items-center justify-between gap-4 rounded-2xl border border-white/8 bg-white/[0.04] px-4 py-4 transition hover:border-cyan-300/30 hover:bg-cyan-300/[0.08]"
                            >
                              <div>
                                <p class="font-medium text-white transition group-hover:text-cyan-100">
                                  {student.full_name}
                                </p>
                                <p class="mt-1 text-sm text-slate-300/70">{student.email ?? "No linked email yet"}</p>
                                <div class="mt-2 flex flex-wrap items-center gap-2">
                                  <span
                                    class:list={[
                                      "rounded-full border px-2.5 py-1 text-[11px] font-medium",
                                      linkStatus.tone,
                                    ]}
                                  >
                                    {linkStatus.label}
                                  </span>
                                  <span class="text-xs text-slate-400/75">{linkStatus.detail}</span>
                                </div>
                              </div>
                              <div class="text-right text-xs text-slate-300/75">
                                <p>
                                  {student.note_count} note{student.note_count === 1 ? "" : "s"}
                                </p>
                                <p class="mt-1">
                                  {student.last_meeting_date
                                    ? `Last meeting ${student.last_meeting_date}`
                                    : rosterView === "archived"
                                      ? "No meetings preserved"
                                      : "No meetings yet"}
                                </p>
                              </div>
                            </a>
                          );
                        })()}
                      </li>
                    ))}
                  </ul>
                )}
              </div>

              <aside class="rounded-[2rem] border border-white/10 bg-linear-to-b from-white/10 to-white/[0.03] p-6 backdrop-blur-xl">
                <p class="text-xs tracking-[0.25em] text-emerald-200/70 uppercase">Phase 3</p>
                <h2 class="mt-3 text-xl font-semibold text-white">Linking status visibility</h2>
                <p class="mt-3 text-sm leading-6 text-slate-200/75">
                  The roster now shows whether each student already claimed access, still has a prepared email waiting
                  for claim, or still needs an email anchor before the student can link their account.
                </p>
                <div class="mt-6 rounded-2xl border border-white/10 bg-slate-950/25 p-4 text-sm text-slate-200/80">
                  <p class="font-medium text-white">Phase 3 contract</p>
                  <p class="mt-2 leading-6">
                    Status stays read-only in this slice. Professors can diagnose onboarding state from the roster
                    without opening relink or account-management controls.
                  </p>
                </div>
                <form method="POST" action="/api/auth/signout" class="mt-6">
                  <button
                    type="submit"
                    class="rounded-xl border border-white/15 bg-white/8 px-4 py-2 text-sm text-white transition hover:bg-white/15"
                  >
                    Sign out
                  </button>
                </form>
              </aside>
            </section>
          </>
        )
      }
    </div>
  </div>
</Layout>
