---
import Layout from "@/layouts/Layout.astro";

const { user, role } = Astro.locals;
---

<Layout title="Dashboard">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="max-w-xl rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
      <p class="mb-3 text-xs tracking-[0.3em] text-blue-200/70 uppercase">Professor workspace</p>
      <h1 class="mb-4 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
        Dashboard
      </h1>
      <p class="text-blue-100/80">
        Signed in as <span class="font-semibold text-white">{user?.email}</span>
      </p>
      <p class="mt-2 text-sm text-blue-100/70">
        Current app role: <span class="font-medium text-white">{role ?? "unknown"}</span>
      </p>
      <p class="mt-4 text-sm text-blue-100/50">
        This temporary professor shell confirms role-aware access before the roster and note-history slices land.
      </p>
      <form method="POST" action="/api/auth/signout" class="mt-6">
        <button
          type="submit"
          class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
        >
          Sign out
        </button>
      </form>
    </div>
  </div>
</Layout>
