---
import Layout from "@/layouts/Layout.astro";
import StudentNoteForm from "@/components/supervision/StudentNoteForm";
import { getStudentHistory } from "@/lib/supervision";
import { createClient } from "@/lib/supabase";

if (Astro.locals.role !== "professor") {
  return Astro.redirect("/dashboard");
}

const supabase = createClient(Astro.request.headers, Astro.cookies);
const studentId = Astro.params.studentId;
const student = supabase && studentId ? await getStudentHistory(supabase, studentId) : null;
const noteCount = student?.notes.length ?? 0;
const defaultMeetingDate = new Date().toISOString().slice(0, 10);
const saved = Astro.url.searchParams.get("saved") === "1";
const updated = Astro.url.searchParams.get("updated") === "1";
const taskUpdated = Astro.url.searchParams.get("taskUpdated");
const error = Astro.url.searchParams.get("error");
const archiveError = Astro.url.searchParams.get("archiveError");
const editNoteId = Astro.url.searchParams.get("edit");
const noteBeingEdited = student?.notes.find((note) => note.id === editNoteId) ?? null;

function getLastEditorLabel(noteUpdatedBy: string) {
  if (!student) {
    return "Unknown collaborator";
  }

  if (noteUpdatedBy === student.professor_profile_id) {
    return "Professor";
  }

  if (noteUpdatedBy === student.student_profile_id) {
    return student.full_name;
  }

  return "Current collaborator";
}

function getCompletionActorLabel(completedBy: string) {
  if (!student) {
    return "Current collaborator";
  }

  if (completedBy === student.professor_profile_id) {
    return "Professor";
  }

  if (completedBy === student.student_profile_id) {
    return student.full_name;
  }

  return "Current collaborator";
}

function formatCompletionTimestamp(value: string) {
  return new Date(value).toLocaleString("en-GB", {
    year: "numeric",
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}
---

<Layout title={student ? `${student.full_name} - Thread` : "Student thread"}>
  <div class="bg-cosmic min-h-screen p-4 text-white">
    <div class="mx-auto flex max-w-5xl flex-col gap-6 py-10">
      <a href="/dashboard" class="text-sm text-cyan-100/80 transition hover:text-cyan-50">Back to student threads</a>

      {
        student ? (
          <>
            <section class="rounded-[2rem] border border-white/10 bg-white/8 p-8 backdrop-blur-xl">
              <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
                <div>
                  <p class="text-xs tracking-[0.3em] text-cyan-200/70 uppercase">Student thread</p>
                  <h1 class="mt-3 text-4xl font-semibold text-white">{student.full_name}</h1>
                  <p class="mt-3 text-sm text-slate-200/75">{student.email ?? "No linked email yet"}</p>
                </div>
                <div class="rounded-2xl border border-white/10 bg-slate-950/20 px-4 py-3 text-sm text-slate-100/80">
                  <p>
                    {noteCount} note{noteCount === 1 ? "" : "s"} in history
                  </p>
                  <p class="mt-1 text-slate-300/70">
                    Professor edits now reuse the shared continuity contract without implying delete or task completion.
                  </p>
                </div>
              </div>
            </section>

            <section class="rounded-[2rem] border border-white/10 bg-slate-950/25 p-6 backdrop-blur-xl">
              <div class="mb-5 flex items-center justify-between gap-4">
                <div>
                  <h2 class="text-xl font-semibold text-white">Chronological history</h2>
                  <p class="mt-2 text-sm text-slate-300/70">
                    This route already loads the student's thread through the new supervision helper so the next phase
                    can focus on richer rendering and note creation.
                  </p>
                </div>
              </div>

              {noteCount === 0 ? (
                <div class="rounded-2xl border border-dashed border-white/15 bg-white/5 p-6 text-sm text-slate-300/75">
                  No notes exist for this student yet.
                </div>
              ) : (
                <ol class="grid gap-4">
                  {student.notes.map((note) => (
                    <li class="rounded-2xl border border-white/8 bg-white/[0.04] p-5">
                      <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                        <div>
                          <p class="text-sm font-medium text-white">Meeting date {note.meeting_date}</p>
                          <p class="mt-1 text-xs text-slate-300/70">
                            Last edited by {getLastEditorLabel(note.updated_by)} on{" "}
                            {new Date(note.updated_at).toLocaleString("en-GB")}
                          </p>
                        </div>
                        <div class="flex flex-wrap items-center gap-2">
                          <span class="rounded-full border border-cyan-300/20 bg-cyan-300/10 px-3 py-1 text-xs text-cyan-100/80">
                            {note.items.length} item{note.items.length === 1 ? "" : "s"}
                          </span>
                          <a
                            href={`/dashboard/students/${student.id}?edit=${note.id}`}
                            class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-100 transition hover:bg-white/10"
                          >
                            Edit note
                          </a>
                        </div>
                      </div>

                      <ul class="mt-4 grid gap-2 text-sm text-slate-100/85">
                        {note.items.map((item) => (
                          <li
                            class:list={[
                              "rounded-xl border px-3 py-3",
                              item.item_type === "task" && item.completed_at
                                ? "border-emerald-300/20 bg-emerald-300/[0.08]"
                                : "border-white/5 bg-slate-950/20",
                            ]}
                          >
                            <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                              <div class="flex gap-3">
                                <span
                                  class:list={[
                                    "mt-0.5 inline-flex h-5 min-w-12 items-center justify-center rounded-full px-2 text-[10px] tracking-[0.2em] uppercase",
                                    item.item_type === "task"
                                      ? "border border-amber-300/25 bg-amber-300/10 text-amber-100"
                                      : "border border-sky-300/25 bg-sky-300/10 text-sky-100",
                                  ]}
                                >
                                  {item.item_type}
                                </span>
                                <div>
                                  <p
                                    class:list={[
                                      "text-sm text-slate-100/90",
                                      item.item_type === "task" &&
                                        item.completed_at &&
                                        "text-slate-300/80 line-through",
                                    ]}
                                  >
                                    {item.content}
                                  </p>

                                  {item.item_type === "task" && item.completed_at && item.completed_by ? (
                                    <p class="mt-2 text-xs text-emerald-100/80">
                                      Completed by {getCompletionActorLabel(item.completed_by)} on{" "}
                                      {formatCompletionTimestamp(item.completed_at)}
                                    </p>
                                  ) : null}
                                </div>
                              </div>

                              {item.item_type === "task" ? (
                                <form
                                  method="POST"
                                  action={`/api/dashboard/students/${student.id}/notes/${note.id}/items/${item.id}/completion`}
                                  class="flex shrink-0 items-center gap-2"
                                >
                                  <input
                                    type="hidden"
                                    name="state"
                                    value={item.completed_at ? "incomplete" : "complete"}
                                  />
                                  <input
                                    type="hidden"
                                    name="returnToEdit"
                                    value={editNoteId === note.id ? note.id : ""}
                                  />
                                  <button
                                    type="submit"
                                    class:list={[
                                      "rounded-full border px-3 py-1.5 text-xs font-medium transition",
                                      item.completed_at
                                        ? "border-amber-300/25 bg-amber-300/10 text-amber-50 hover:bg-amber-300/20"
                                        : "border-emerald-300/25 bg-emerald-300/10 text-emerald-50 hover:bg-emerald-300/20",
                                    ]}
                                  >
                                    {item.completed_at ? "Reopen task" : "Mark done"}
                                  </button>
                                </form>
                              ) : null}
                            </div>
                          </li>
                        ))}
                      </ul>
                    </li>
                  ))}
                </ol>
              )}
            </section>

            <section class="rounded-[2rem] border border-white/10 bg-white/[0.06] p-6 backdrop-blur-xl">
              <div class="mb-5 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
                <div>
                  <p class="text-xs tracking-[0.3em] text-emerald-200/70 uppercase">
                    {noteBeingEdited ? "Edit note" : "New note"}
                  </p>
                  <h2 class="mt-2 text-xl font-semibold text-white">
                    {noteBeingEdited
                      ? `Update ${noteBeingEdited.meeting_date} without rewriting the thread`
                      : "Capture the next supervision update"}
                  </h2>
                  <p class="mt-2 text-sm text-slate-300/75">
                    {noteBeingEdited
                      ? "Edit saved items in place and append new ones at the end. Deleting saved items stays out of scope for this slice."
                      : "Add one dated note directly inside this thread. Item order is preserved exactly as entered."}
                  </p>
                </div>
              </div>

              {saved ? (
                <div class="mb-4 rounded-2xl border border-emerald-300/20 bg-emerald-300/10 px-4 py-3 text-sm text-emerald-50">
                  The note was saved to this thread.
                </div>
              ) : null}

              {updated ? (
                <div class="mb-4 rounded-2xl border border-emerald-300/20 bg-emerald-300/10 px-4 py-3 text-sm text-emerald-50">
                  The note changes were saved to this thread.
                </div>
              ) : null}

              {taskUpdated === "complete" ? (
                <div class="mb-4 rounded-2xl border border-emerald-300/20 bg-emerald-300/10 px-4 py-3 text-sm text-emerald-50">
                  The task was marked as completed in this thread.
                </div>
              ) : null}

              {taskUpdated === "incomplete" ? (
                <div class="mb-4 rounded-2xl border border-amber-300/20 bg-amber-300/10 px-4 py-3 text-sm text-amber-50">
                  The task was reopened in this thread.
                </div>
              ) : null}

              {error ? (
                <div class="mb-4 rounded-2xl border border-rose-300/20 bg-rose-300/10 px-4 py-3 text-sm text-rose-50">
                  {error}
                </div>
              ) : null}

              <StudentNoteForm
                client:load
                action={`/api/dashboard/students/${student.id}/notes`}
                defaultMeetingDate={noteBeingEdited?.meeting_date ?? defaultMeetingDate}
                defaultItems={
                  noteBeingEdited?.items.map((item) => ({
                    id: item.id,
                    itemType: item.item_type,
                    content: item.content,
                  })) ?? undefined
                }
                meetingDateReadOnly={Boolean(noteBeingEdited)}
                mode={noteBeingEdited ? "edit" : "create"}
                noteId={noteBeingEdited?.id}
              />
            </section>

            {student.lifecycle === "active" ? (
              <section class="rounded-[2rem] border border-rose-300/20 bg-rose-300/[0.06] p-6 backdrop-blur-xl">
                <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                  <div class="max-w-2xl">
                    <p class="text-xs tracking-[0.3em] text-rose-200/70 uppercase">Danger zone</p>
                    <h2 class="mt-2 text-xl font-semibold text-white">Archive this student</h2>
                    <p class="mt-2 text-sm leading-6 text-slate-200/75">
                      Archiving removes this student from the active roster and ends their current student access. The
                      historical thread stays preserved for professor-only archive work in a later slice.
                    </p>
                  </div>
                  <span class="rounded-full border border-rose-300/20 bg-rose-300/10 px-3 py-1 text-xs text-rose-50/80">
                    Irreversible in product
                  </span>
                </div>

                {archiveError ? (
                  <div class="mt-4 rounded-2xl border border-rose-300/20 bg-rose-300/10 px-4 py-3 text-sm text-rose-50">
                    {archiveError}
                  </div>
                ) : null}

                <form method="POST" action={`/api/dashboard/students/${student.id}/archive`} class="mt-5 space-y-4">
                  <label class="flex items-start gap-3 rounded-2xl border border-white/10 bg-slate-950/25 p-4 text-sm text-slate-100/85">
                    <input
                      type="checkbox"
                      name="confirmArchive"
                      value="yes"
                      class="mt-1 size-4 rounded border-white/20 bg-slate-950/60 text-rose-300"
                      required
                    />
                    <span class="leading-6">
                      I understand that this will remove <span class="font-medium text-white">{student.full_name}</span>{" "}
                      from the active roster and end the current student access for this thread.
                    </span>
                  </label>

                  <div class="flex justify-end">
                    <button
                      type="submit"
                      class="rounded-xl border border-rose-300/25 bg-rose-300/10 px-4 py-2 text-sm font-medium text-rose-50 transition hover:bg-rose-300/20"
                    >
                      Archive student
                    </button>
                  </div>
                </form>
              </section>
            ) : null}
          </>
        ) : (
          <section class="rounded-[2rem] border border-white/10 bg-slate-950/25 p-8 backdrop-blur-xl">
            <p class="text-xs tracking-[0.3em] text-amber-200/70 uppercase">Student thread</p>
            <h1 class="mt-3 text-3xl font-semibold text-white">Thread unavailable</h1>
            <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-200/75">
              This student could not be loaded from the current professor-visible graph. The route is in place, but the
              requested student id is missing or not accessible in this environment.
            </p>
          </section>
        )
      }
    </div>
  </div>
</Layout>
