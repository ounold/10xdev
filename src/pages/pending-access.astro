---
import Layout from "@/layouts/Layout.astro";

const { user, isLinkedStudent } = Astro.locals;
---

<Layout title="Pending access">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div
      class="max-w-xl rounded-2xl border border-amber-200/20 bg-white/10 p-8 text-center text-white backdrop-blur-xl"
    >
      <p class="mb-3 text-xs tracking-[0.3em] text-amber-200/70 uppercase">Access pending</p>
      <h1 class="mb-4 bg-gradient-to-r from-amber-100 to-orange-200 bg-clip-text text-3xl font-bold text-transparent">
        Your account is ready, but product access is not.
      </h1>
      <p class="text-blue-100/80">
        Signed in as <span class="font-semibold text-white">{user?.email}</span>
      </p>
      <p class="mt-4 text-sm text-blue-100/70">
        {
          isLinkedStudent
            ? "This account is linked to a student profile, but the student-facing history view has not shipped yet."
            : "This account exists, but it has not been assigned professor access or linked student access yet."
        }
      </p>
      <p class="mt-2 text-sm text-blue-100/50">
        Please contact the professor workspace owner if you believe you should already have access.
      </p>
      <form method="POST" action="/api/auth/signout" class="mt-6">
        <button
          type="submit"
          class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
        >
          Sign out
        </button>
      </form>
    </div>
  </div>
</Layout>
