---
import { buildPendingAccessViewModel } from "@/lib/pending-access";
import { getStudentLinkClaimabilityForUser } from "@/lib/profile";
import Layout from "@/layouts/Layout.astro";

const { user, isLinkedStudent } = Astro.locals;
const claimError = Astro.url.searchParams.get("claimError");

let claimability: Awaited<ReturnType<typeof getStudentLinkClaimabilityForUser>> | null = null;
let claimabilityError: string | null = null;

if (user) {
  try {
    claimability = await getStudentLinkClaimabilityForUser(user);
  } catch (error) {
    claimabilityError = error instanceof Error ? error.message : "Student account linking is unavailable right now.";
  }
}

const viewModel = buildPendingAccessViewModel({
  claimability,
  claimabilityError,
  claimError,
  isLinkedStudent,
});
---

<Layout title="Pending access">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div
      class="max-w-xl rounded-2xl border border-amber-200/20 bg-white/10 p-8 text-center text-white backdrop-blur-xl"
    >
      <p class="mb-3 text-xs tracking-[0.3em] text-amber-200/70 uppercase">Access pending</p>
      <h1 class="mb-4 bg-gradient-to-r from-amber-100 to-orange-200 bg-clip-text text-3xl font-bold text-transparent">
        Your account is ready, but product access is not.
      </h1>
      <p class="text-blue-100/80">
        Signed in as <span class="font-semibold text-white">{user?.email}</span>
      </p>
      {
        viewModel.feedback ? (
          <div class="mt-4 rounded-xl border border-amber-200/25 bg-amber-100/10 px-4 py-3 text-left text-sm text-amber-100">
            {viewModel.feedback}
          </div>
        ) : null
      }
      <div class="mt-4 space-y-3 text-left text-sm text-blue-100/75">
        <p>{viewModel.body}</p>
        {viewModel.detail ? <p class="text-blue-100/55">{viewModel.detail}</p> : null}
      </div>
      <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        {
          viewModel.can_claim ? (
            <form method="POST" action="/api/student/claim-access">
              <button
                type="submit"
                class="rounded-lg border border-emerald-200/30 bg-emerald-200/15 px-4 py-2 text-sm font-medium text-emerald-50 transition-colors hover:bg-emerald-200/25"
              >
                Link my student access
              </button>
            </form>
          ) : null
        }
        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
          >
            Sign out
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
